# Social media credentials for integration testing.
# Copy to .env.social and fill in real values.
# This file is gitignored — never commit real credentials.
#
# Usage:
#   env $(cat .env.social | xargs) pytest tests/production/test_social_integration.py -v --headed -s

# Instagram (Business account linked to Facebook Page)
IG_USER_ID=
IG_ACCESS_TOKEN=

# Facebook Page
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# LinkedIn
LI_ACCESS_TOKEN=
LI_PERSON_URN=
LI_API_VERSION=
