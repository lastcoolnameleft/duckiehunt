# Docker / Compose
COMPOSE_PROJECT_NAME=duckiehunt
IMAGE=ghcr.io/lastcoolnameleft/duckiehunt:latest
DATA_DIR=./data
# Set this to the env file you pass to `docker compose --env-file`
ENV_FILE=.env
TRAEFIK_HOST=localhost
TRAEFIK_NETWORK=traefik
DEPLOY_ENV=local
GIT_SHA=development
WATCHTOWER_POLL_INTERVAL=300

# Django settings module
DJANGO_SETTINGS_MODULE=duckiehunt.settings.local

# Django core
DJANGO_SECRET_KEY=
DJANGO_DEBUG=
DJANGO_ALLOWED_HOSTS=
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_BASE_URL=
DJANGO_EMAIL_FROM=
DJANGO_EMAIL_TO=

# Email
SENDGRID_API_KEY=

# reCAPTCHA
RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=

# Social auth
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=
SOCIAL_AUTH_FACEBOOK_KEY=
SOCIAL_AUTH_FACEBOOK_SECRET=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Flickr
FLICKR_API_KEY=
FLICKR_API_SECRET=
FLICKR_AUTH_FILE=
FLICKR_PHOTO_IS_PUBLIC=

# Database (SQLite only; set either DATABASE_PATH or DATABASE_URL)
DATABASE_PATH=
DATABASE_URL=
